[user]
	name = bhoeber
	email = ben.hoeber@sulzmann.energy
[push]
	autoSetupRemote = true
[core]
	editor = nvim
	whitespace = trailing-space,space-before-tab
	pager = delta
[alias]
	pfl = push --force-with-lease
	ribase = rebase -i --autosquash
    amend = commit --amend --no-edit
	lgg = log --graph --oneline --all --abbrev-commit
	logg = log --graph --all --abbrev-commit
[rerere]
	enabled = true
	autoupdate = true
[color]
	ui = auto
[diff]
	colorMoved = default
	tool = nvimdiff
[merge]
	renames = true            # besseres Erkennen von Datei-Umbenennungen
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[maintenance]
	repo = /home/bhoeber/Git/Malzfabrik/analyse-anlagendaten
	repo = /home/bhoeber/Git/Malzfabrik/Darren-Abwaerme-Konzept
[merge]
    conflictStyle = zdiff3
[init]
	defaultBranch = main
[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
[interactive]
	name = bhoeber
	email = ben.hoeber@sulzmann.energy
