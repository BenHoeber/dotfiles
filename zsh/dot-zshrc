# Yazi setup to jump to cwd
function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		z -- "$cwd"
	fi
	rm -f -- "$tmp"
}

# Run “nh” followed by any command to start it under nohup,
# with all I/O discarded and returned to the prompt immediately.
nh() {
  # background, detach from tty, silence all output, *and* disown
  nohup "$@" </dev/null >/dev/null 2>&1 &!
}

