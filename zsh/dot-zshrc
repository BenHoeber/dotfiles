########## Key mode ##########
bindkey -v  # use vim-style keys

########## History ##########
HISTFILE=${ZDOTDIR:-$HOME}/.zsh_history
HISTSIZE=200000
SAVEHIST=200000
setopt inc_append_history       # append immediately
setopt extended_history         # timestamps etc.
setopt hist_reduce_blanks
setopt hist_ignore_dups         # ignore duplicate of previous
setopt hist_ignore_all_dups     # remove older duplicates
setopt hist_verify              # expand history, then edit before running
# setopt share_history            # share across terminals

########## Sensible defaults ##########
setopt autocd                   # 'foo' = cd foo
setopt glob_dots                # include dotfiles in globs
setopt interactive_comments
setopt no_beep
setopt nobeep                                                   # No beep
setopt notify
unsetopt flow_control           # keep ^S/^Q from freezing the TTY
setopt no_nomatch               # wildcard that doesn't match won't error
setopt numericglobsort          # Sort filenames numerically when it makes sense
unsetopt auto_menu		# Disable zshs internal completion menu in favour of fzf

WORDCHARS=${WORDCHARS//\/[&.;]} # Don't consider certain characters part of the word

########## PATH ##########
path=("$HOME/.local/bin" $path)
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
export PATH="$HOME/.cargo/bin:$PATH"

########## Colors (for zstyles etc.) ##########
autoload -Uz colors && colors

########## Completion system (merged) ##########
# Extra completion functions installed by packages
fpath+=(/usr/share/zsh/site-functions)

autoload -Uz compinit
# Harden permissions if compaudit complains (one-time fix)
# if ! compaudit &>/dev/null; then
#   compaudit | xargs -r chmod g-w,o-w 2>/dev/null
# fi
# Use versioned compdump under XDG cache for speed
ZSH_COMPDUMP="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/zcompdump-$ZSH_VERSION"
mkdir -p "${ZSH_COMPDUMP:h}"
compinit -d "$ZSH_COMPDUMP"

# Modules & base styles
zmodload -i zsh/complist
# Chain of completers: complete → ignore-mask → matching → corrections → approx → prefix
zstyle ':completion:*' completer _complete _ignored _match _correct _approximate _prefix

# Don’t insert common unambiguous prefix automatically (works better with fzf-tab)
zstyle ':completion:*' insert-unambiguous false

# Colors for completion lists (use LS_COLORS)
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}

# Matching rules: smart case + tolerate separators, keep your original-both behavior
zstyle ':completion:*' matcher-list \
  'm:{a-zA-Z}={A-Za-z}' \
  'r:|[._-]=* r:|=*'
zstyle ':completion:*' match-original both

# Limit number of typos accepted by approximate matching
zstyle ':completion:*' max-errors 2

# Fallback menu behavior (fzf-tab overrides UI when active)
zstyle ':completion:*' menu select

# Grouping & descriptions (bold + cyan)
zstyle ':completion:*' group-name ''
zstyle ':completion:*:descriptions' format '[%d]'
# Classic prompts (used if fzf-tab isn’t engaged)
zstyle ':completion:*' list-prompt '%SAt %p: Hit TAB for more, or the character to insert%s'
zstyle ':completion:*' select-prompt '%SScrolling active: current selection at %l%s'
zstyle ':completion:*' prompt '[%e errors] - Did you mean:'
#
# Speed up completions
# zstyle ':completion:*' accept-exact '*(N)'
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.zsh/cache

