{
  "layer": "top",
  "position": "top",
  "exclusive": true,
  "gdk-layer-shell": true,
  "height": 40,
  "spacing": 3,
  "modules-left": ["custom/spacer", "clock#simpleclock", "custom/spacer", "sway/workspaces", "sway/scratchpad", "sway/mode", "mpris",],
  "modules-center": [
  "sway/window"
  ],
  "modules-right": [
    "cpu",
    "memory",
    "sway/language",
    "pulseaudio",
    "battery",
    "clock",
    "tray",
    "custom/notification",
    "custom/power",
    "custom/spacer",
  ],
  "mpris": {
    "player": "spotify",
    "dynamic-order": ["title", "artist"],
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} <i>{dynamic}</i>",
    "status-icons": {
      "paused": "пЃЊ",
    },
    "player-icons": {
      "default": "пЃ‹",
    },
  },
  "sway/workspaces": {
    "disable-scroll": true
  },
  "sway/scratchpad": {
      "format": "{icon} {count}",
      "show-empty": true,
      "format-icons": ["п‹’", "п‹’"],
      "tooltip": true,
      "tooltip-format": "{title}",
      "expand": true,
      "on-click": "swaymsg 'scratchpad show'",
  },
  "sway/window": {
    "format": "{title}",
    "max-length": 50,
    "on-click": "swaymsg fullscreen",
    "show-focused-workspace-name": true,
    "icon": true,
    "icon-size": 14,
  },
  "tray": {
    "show-passive-items": true,
    "spacing": 10,
  },
  "clock#simpleclock": {
    "tooltip": false,
    "format": "пЂ— {:%H:%M}",
  },
  "clock": {
    "format": "пЃі {:L%a %d %b}",
    "calendar": {
      "format": {
        "days": "<span weight='normal'>{}</span>",
        "months": "<span color='#cdd6f4'><b>{}</b></span>",
        "today": "<span color='#f38ba8' weight='700'><u>{}</u></span>",
        "weekdays": "<span color='#f9e2af'><b>{}</b></span>",
        "weeks": "<span color='#a6e3a1'><b>W{}</b></span>",
      },
      "mode": "month",
      "mode-mon-col": 1,
      "on-scroll": 1,
    },
    "tooltip-format": "<span color='#cdd6f4' font='Lexend 16'><tt><small>{calendar}</small></tt></span>",
  },
  "cpu": {
    "format": "п‹› {usage}%",
    "tooltip": true,
    "interval": 1,
  },
  "memory": {
    "format": "ої… {used:0.1f}Gi",
  },
  "sway/language": {
      "format": "{}",
      "on-click": "swaymsg input type:keyboard xkb_switch_layout next",
  },
  "battery": {
      "format": "{capacity}% {icon}",
      "format-charging": "{capacity}% {icon}",
      "format-full": "{capacity}% {icon}",
      "format-icons": {
          "full": ["п‰Ђ "],
          "charging": ["у°ўњ", "у°‚†", "у°‚‡", "у°‚€", "у°‚‰"],
          "discharging": ["п‰„ ", "п‰ѓ ", "п‰‚ ", "п‰Ѓ ", "п‰Ђ "]
      },
      "interval": 10
  },
  "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-muted": "п‘¦  muted",
      "format-icons": {
          "headphone": "пЂҐ",
          "default": ["пЂ¦ ", "пЂ§ ", "пЂЁ "],
      },
      "on-click": "pavucontrol",
  },
  "custom/sep": {
      "format": "|",
      "tooltip": false,
  },
  "custom/power": {
      "tooltip": false,
      "on-click": "wlogout -p layer-shell &",
      "format": "вЏ»",
  },
  "custom/notification": {
      "escape": true,
      "exec": "swaync-client -swb",
      "exec-if": "which swaync-client",
      "format": "{icon}",
      "margin": "5px",
      "format-icons": {
          "none": "у°…є",
          "notification": "у°Ўџ",
          "dnd-notification:": "у°‚ћ",
      },
      "on-click": "sleep 0.1 && swaync-client -t -sw",
      "return-type": "json",
      "tooltip": false,
  },
  "custom/spacer": {
      "format": "\u200A",
  }
}
